# Veritabanı (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=stoksay_user
DB_PASSWORD=your-db-password-here
DB_NAME=stoksay

# Sunucu
PORT=3001
NODE_ENV=development

# JWT Secret — En az 32 karakter uzunluğunda güçlü bir secret
# Oluşturmak için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here-min-32-chars

# CORS: Frontend URL'lerini virgülle ayırarak girin
# Geliştirme: http://localhost:5173
# Üretim örneği: https://stoksay.com,https://www.stoksay.com
ALLOWED_ORIGINS=http://localhost:5173
